# Webhook server (set to your Render URL after deploy)
WEBHOOK_BASE_URL=https://tenacious-webhook-server.onrender.com

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Resend (email sending)
RESEND_API_KEY=re_...

# HubSpot Developer Sandbox
HUBSPOT_ACCESS_TOKEN=pat-na1-...

# Cal.com self-hosted
CAL_API_KEY=cal_...
CAL_BASE_URL=http://localhost:3000/api/v1

# Africa's Talking (SMS)
AT_API_KEY=atsk_...
AT_USERNAME=sandbox

# Langfuse observability
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Webhook signing secrets (set in each platform dashboard)
RESEND_WEBHOOK_SECRET=whsec_...
CAL_WEBHOOK_SECRET=...

# OpenRouter (tau2-bench)
OPENROUTER_API_KEY=sk-or-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=${OPENROUTER_API_KEY}

# Twilio Voice (outbound discovery calls — bonus demo item)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TENACIOUS_SALES_PHONE=+1xxxxxxxxxx

# Demo helpers
DEMO_PHONE=+1xxxxxxxxxx
AT_SHORTCODE=
